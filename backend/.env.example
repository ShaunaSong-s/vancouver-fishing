# AI Provider (choose one)
# Option 1: Google Gemini (Free - 15 RPM, 1M tokens/day)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Groq (Free - Llama 3, very fast)
GROQ_API_KEY=your_groq_api_key_here

# Choose provider: "gemini" or "groq"
AI_PROVIDER=gemini

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fishing_app
REDIS_URL=redis://localhost:6379

# External APIs
# Environment Canada Weather (free, no key needed)
WEATHER_API_URL=https://api.weather.gc.ca

# DFO Tides (free)
TIDES_API_URL=https://api-iwls.dfo-mpo.gc.ca/api/v1

# App Settings
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=*
